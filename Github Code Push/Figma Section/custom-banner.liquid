



<section class="custom_nav_banner" id="{{section.id}}" >


   <div class="data_images_block">
    <div class="image_data">
          <div class="image_block">
            {% if section.settings.main_data_image != blank %}
              <img class="data_image" src="{{ section.settings.main_data_image | img_url: 'master' }}" alt="{{ section.settings.main_data_image.alt }}">
            {% endif %}
          </div>


          <div class="mobile_view" style="display: none;">
            {% if section.settings.mobile_view != blank %}
              <img class="data_images" src="{{ section.settings.mobile_view | img_url: 'master' }}" alt="{{ section.settings.mobile_view.alt }}">
            {% endif %}
          </div>
          </div>
            <div class="page-width">
    <div class="page_warpper">


      <div class="image_text">


        <div class="content_block">


          <h1 class="hero-heading">
            {{ section.settings.heading_text }}
            <span
              class="highlight-text"
              style="color: {{ section.settings.highlight_color }};"
            >
              {{ section.settings.highlight_text }}
            </span>
          </h1>
          {%  if section.settings.subtext != blank %}
          <p class="hero-subtext">
            {{ section.settings.subtext }}
          </p>
        {% endif %}


          {% if section.settings.button_text != blank %}
            <a href="{{ section.settings.button_link }}" class="bundle-btn">
              {{ section.settings.button_text }}
            </a>
          {% endif %}


        </div>
      </div>


    </div>
  </div>


        </div>




</section>


 {% schema %}
{
  "name": "Bundle Banner Section",
  "settings": [
{
      "type": "image_picker",
      "id": "main_data_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_view",
      "label": "Main Mobile Image"
    },
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Smart stack, smarter price - shop curated bundles and"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Text",
      "default": "save 30%."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Clinically informed formulas that support energy, balance, and everyday wellness."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#00bcd4"
    },
   
    {
  "type": "text",
  "id": "button_text",
  "label": "Button Text",
  "default": "Shop Now"
},
{
  "type": "url",
  "id": "button_link",
  "label": "Button Link"
},
{
  "type": "color",
  "id": "btn_bg",
  "label": "Button Background",
  "default": "#00bcd4"
},
{
  "type": "color",
  "id": "btn_text",
  "label": "Button Text Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "btn_hover_bg",
  "label": "Button Hover Background",
  "default": "#0097a7"
},
{
  "type": "image_picker",
  "id": "bg_image",
  "label": "Background Image (Desktop)"
},
{
  "type": "image_picker",
  "id": "bg_image_mobile",
  "label": "Background Image (Mobile)"
},
{
  "type": "color",
  "id": "overlay_color",
  "label": "Overlay Color",
  "default": "#000000"
},
{
  "type": "range",
  "id": "overlay_opacity",
  "label": "Overlay Opacity",
  "min": 0,
  "max": 100,
  "step": 5,
  "default": 40
}
  ],
  "presets": [
    {
      "name": "Bundle Banner Section"
    }
  ]
}
{% endschema %}








<style>
 
   #{{section.id}}.custom_nav_banner {
    width: 100%;
    position: relative;
    border-bottom-left-radius: 30px;
    border-bottom-right-radius: 30px;
    overflow: hidden;
}


#{{section.id}} .image_block {
    font-size: 0;
}


/* Overlay */
#{{section.id}}.custom_nav_banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
}


/* Keep content above overlay */
#{{section.id}}.custom_nav_banner .page-width {
   position: absolute;
    z-index: 9999;
    inset: 0;
    display: flex;
    justify-content: flex-start;
    align-items: center;
}
#{{section.id}} .data_images_block {
    position: relative;
}


  #{{section.id}} .bundle-btn {
    display: inline-block;
    padding: 14px 30px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    border-radius: 50px;
    text-decoration: none;
    font-family: 'Nunito Sans';
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
    width: fit-content;
}


#{{section.id}} .bundle-btn:hover {
    background: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
    transform: translateY(-2px);
}
 
#{{section.id}} .custom_nav_banner {
    width: 100%;
    position: relative;
    background: #000;
    border-bottom-left-radius: 30px;
    border-bottom-right-radius: 30px;
}
#{{section.id}}.custom_nav_banner .page-width {
    max-width: 1440px !important;
   
}
#{{section.id}}.custom_nav_banner .page_warpper {
    width: 100%;
    position: relative;
}




#{{section.id}}.custom_nav_banner .page_warpper .image_text .content_block {
    width: 38%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 50px;
}
#{{section.id}}.custom_nav_banner .page_warpper .image_text .data_images_block {
    width: 62%;
}
#{{section.id}}.custom_nav_banner .page_warpper .image_text .data_images_block .image_block {
    width: 100%;
    font-size: 0;
}
#{{section.id}}.custom_nav_banner .page_warpper .image_text .data_images_block .image_block img.data_image {
    width: 100%;
    display: block;
        border-bottom-right-radius: 30px;
}
#{{section.id}}.custom_nav_banner .page_warpper .image_text .content_block h1.hero-heading {
    font-family: 'Libre Baskerville';
    font-weight: 400;
    font-size: 38px;
    line-height: 48px;
    letter-spacing: 0%;
    vertical-align: middle;
    color: #ffffff;
    margin: 0;
    max-width: 470px;
}
#{{section.id}}.custom_nav_banner .page_warpper .image_text .content_block p.hero-subtext {
    margin: 0;
    font-family: 'Nunito Sans';
    font-weight: 400;
    font-size: 23px;
    line-height: 30px;
    letter-spacing: 0%;
    vertical-align: middle;
    color: #ffffff;
    max-width: 550px;
}
.mobile-menu ul li {
  opacity: 0;
  transform: translateX(-20px);
  transition: all 0.3s ease;
}


.mobile-menu.active ul li {
  opacity: 1;
  transform: translateX(0);
}
.custom-header .search-modal.modal__content.gradient .modal-overlay::after {
content: unset;
}
.custom-header .search-modal.modal__content.gradient {
    border-radius: 100px;
    background: #9cccd7;
}
.custom-header .search-modal.modal__content.gradient .field::after {
  content: '';
  border-radius:100px;
}
.custom-header .search-modal.modal__content.gradient .field input {
    border-radius: 100px;
}


#{{section.id}} img.data_image {
    position: relative;
    width: 100%;
    background-position: center;
    background-repeat: repeat;
    background-size: cover;
    z-index: 999;
}


