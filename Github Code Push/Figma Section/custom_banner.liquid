<section class="custom_nav_banner">
    <div class="page-width">
        <div class="page_warpper">
{% comment %} 
<header class="custom-header">
  <div class="header-wrapper">

    <!-- LEFT: Hamburger -->
    <div class="header-left">
      <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>

    <!-- CENTER: Logo -->
    <div class="header-logo header-center">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo %}
          <img src="{{ section.settings.logo | image_url }}" alt="logo">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Desktop Menu -->
    <nav class="header-menu">
      <ul>
        {% for link in linklists[section.settings.menu].links %}
          <li class="{% if link.links != blank %}has-dropdown{% endif %}">
            <a href="{{ link.url }}">{{ link.title }}</a>

            {% if link.links != blank %}
              <ul class="dropdown">
                {% for child in link.links %}
                  <li>
                    <a href="{{ child.url }}">{{ child.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- RIGHT: Icons (FULL DAWN LOGIC) -->
    <div class="header-icons header-right">

      <!-- 🌍 Localization -->
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'HeaderCountryForm' -%}
              {% render 'country-localization' %}
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'HeaderLanguageForm' -%}
              {% render 'language-localization' %}
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      <!-- 🔍 Search -->
      {% render 'header-search', input_id: 'Search-In-Modal' %}

      <!-- 👤 Account -->
      {%- if shop.customer_accounts_enabled -%}
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="header__icon account-icon">
          <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
        </a>
      {%- endif -%}

      <!-- 🧩 App Blocks -->
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <!-- 🛒 Cart -->
      <a 
  href="{{ routes.cart_url }}" 
  class="header__icon header__icon--cart js-cart-toggle" 
  id="cart-icon-bubble"
>
  {% if cart == empty %}
    <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
  {% else %}
    <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
  {% endif %}

  {% if cart != empty %}
    <div class="cart-count-bubble">
      <span>{{ cart.item_count }}</span>
    </div>
  {% endif %}
</a>

    </div>

  </div>

  <!-- Mobile Menu -->
<!-- MOBILE DRAWER -->
<div class="mobile-menu">

  <!-- Close Button -->
  <div class="menu-header">
    <button class="menu-close">✕</button>
  </div>

  <ul>
    {% for link in linklists[section.settings.menu].links %}
      <li>
        <a href="{{ link.url }}">{{ link.title }}</a>

        {% if link.links != blank %}
          <ul>
            {% for child in link.links %}
              <li><a href="{{ child.url }}">{{ child.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>

</div>

<!-- OVERLAY -->
<div class="mobile-overlay"></div>

  <!-- 🔥 REQUIRED DAWN COMPONENTS -->

  {% render 'cart-drawer' %}

</header> {% endcomment %}

<div class="image_text">

<div class="content_block">

<h2 class="hero-heading">
  {{ section.settings.heading_text }}
  <span 
    class="highlight-text"
    style="color: {{ section.settings.highlight_color }};"
  >
    {{ section.settings.highlight_text }}
  </span>
</h2>

  <p class="hero-subtext">
    {{ section.settings.subtext }}
  </p>

</div>



<div class="data_images_block">
<div class="image_block">
{% if section.settings.main_data_image != blank %}
<img class="data_image" src="{{ section.settings.main_data_image | img_url: 'master' }}">
{% endif %}
</div>
<div class="mobile_view" style="display: none;">
{% if section.settings.mobile_view != blank %}
<img class="data_images" src="{{ section.settings.mobile_view | img_url: 'master' }}">
{% endif %}
</div>
</div>
</div>
            </div>
            </div>
            </section>

            {% schema %}
{
  "name": "Custom Nav Banner",
  "settings": [
    
     {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },

    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Smart stack, smarter price - shop curated bundles and"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Text",
      "default": "save 30%."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Clinically informed formulas that support energy, balance, and everyday wellness."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#00bcd4"
    },
    {
      "type": "image_picker",
      "id": "main_data_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_view",
      "label": "Main Mobile Image"
    },
  ],
  "presets": [
    {
      "name": "Custom Nav Banner"
    }
  ]
}
{% endschema %}


 <style>
 
.custom_nav_banner {
    width: 100%;
    position: relative;
    background: #082D35;
        border-bottom-left-radius: 30px;
         border-bottom-right-radius: 30px;
}
.custom_nav_banner .page-width {
    max-width: 1440px !important;
    
}
.custom_nav_banner .page_warpper {
    width: 100%;
    position: relative;
}
.custom_nav_banner .page_warpper .image_text {
    display: flex;
    align-items: center;
    width: 100%;
    justify-content: space-between;
    width: calc(100vw - ((101vw - 100%) / 2));
    margin-right: calc(48% - 50vw);
    overflow: visible;
}
.custom_nav_banner .page_warpper .image_text .content_block {
    width: 38%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 50px;
}
.custom_nav_banner .page_warpper .image_text .data_images_block {
    width: 62%;
}
.custom_nav_banner .page_warpper .image_text .data_images_block .image_block {
    width: 100%;
    font-size: 0;
}
.custom_nav_banner .page_warpper .image_text .data_images_block .image_block img.data_image {
    width: 100%;
    display: block;
        border-bottom-right-radius: 30px;
}
.custom_nav_banner .page_warpper .image_text .content_block h2.hero-heading {
    font-family: 'Libre Baskerville';
    font-weight: 400;
    font-size: 38px;
    line-height: 48px;
    letter-spacing: 0%;
    vertical-align: middle;
    color: #ffffff;
    margin: 0;
    max-width: 470px;
}
.custom_nav_banner .page_warpper .image_text .content_block p.hero-subtext {
    margin: 0;
    font-family: 'Nunito Sans';
    font-weight: 400;
    font-size: 24px;
    line-height: 30px;
    letter-spacing: 0%;
    vertical-align: middle;
    color: #ffffff;
    max-width: 550px;
}
.mobile-menu ul li {
  opacity: 0;
  transform: translateX(-20px);
  transition: all 0.3s ease;
}

.mobile-menu.active ul li {
  opacity: 1;
  transform: translateX(0);
}
.custom-header .search-modal.modal__content.gradient .modal-overlay::after {
content: unset;
}
.custom-header .search-modal.modal__content.gradient {
    border-radius: 100px;
    background: #9cccd7;
}
.custom-header .search-modal.modal__content.gradient .field::after {
  content: '';
  border-radius:100px; 
}
.custom-header .search-modal.modal__content.gradient .field input {
    border-radius: 100px;
}

@media (max-width: 1440px) {
.custom_nav_banner .page_warpper .image_text .content_block {
    width: 45%;
   
}
.custom_nav_banner .page_warpper .image_text {

    width: calc(100vw - ((100vw - 100%) / 2));
   
}
.custom_nav_banner .page_warpper .image_text .data_images_block {
    width: 55%;
}
    .custom_nav_banner .header-wrapper {
       
        margin: 0px 20px;
    }

}
@media (max-width: 1095px) {
.custom_nav_banner .page_warpper .image_text .content_block {
   
    padding-top: 120px;
}
}

@media (max-width: 1024px) {


.custom_nav_banner .page_warpper .image_text .content_block h2.hero-heading {
    font-size: 32px;
      line-height: 35px;
    
}
.custom_nav_banner .page_warpper .image_text .content_block p.hero-subtext {
        font-size: 18px;
    line-height: 22px;
   }
}

@media (max-width: 989px) {
.custom_nav_banner .page_warpper .image_text {
    flex-direction: column-reverse;
    width: 100%;
}
    .custom_nav_banner .page_warpper .image_text .content_block {
                width: 100%;
        padding: 0px 20px;
       margin: -80px;
        padding-bottom: 120px;
    }
.custom_nav_banner .page_warpper .image_text .data_images_block .image_block {
    
    display: none;
}
.custom_nav_banner .page_warpper .image_text .data_images_block .mobile_view {
    display: inline-block !important;
}
.custom_nav_banner .page_warpper .image_text .data_images_block .mobile_view img.data_images {
    width: 100%;
    display: inline-flex;
}
.custom_nav_banner .page_warpper .image_text .data_images_block {
        width: 100%;
    }
    .custom_nav_banner {
    border-radius: unset;
}
}

@media (max-width: 768px) {

    .custom_nav_banner .page-width {
    max-width: 1440px !important;
    padding: 0;
}
.custom_nav_banner .page_warpper .image_text .content_block h2.hero-heading {
        font-size: 28px!important;
        line-height: 29px;
        max-width: 370px !important;
    }
        .custom_nav_banner .page_warpper .image_text .content_block p.hero-subtext {
  
    max-width: 390px;
}
}


@media (max-width: 500px) {
    .custom_nav_banner .page_warpper .image_text .content_block {
        width: 100%;
     margin: -70px;
    }
    .custom_nav_banner .page_warpper .image_text .content_block {
       
        padding-bottom: 100px;
    }
        .custom_nav_banner .page_warpper .image_text .content_block p.hero-subtext {
        font-size: 16px;
        line-height: 20px;
    }
  }
</style>



<script>
document.addEventListener('DOMContentLoaded', function () {

  const hamburger = document.querySelector('.hamburger');
  const mobileMenu = document.querySelector('.mobile-menu');
  const overlay = document.querySelector('.mobile-overlay');
  const closeBtn = document.querySelector('.menu-close');

  if (!hamburger || !mobileMenu) return;

  // OPEN MENU
  hamburger.addEventListener('click', function () {
    mobileMenu.classList.add('active');
    overlay.classList.add('active');
  });

  // CLOSE MENU (CROSS BUTTON)
  closeBtn.addEventListener('click', function () {
    mobileMenu.classList.remove('active');
    overlay.classList.remove('active');
  });

  // CLOSE ON OVERLAY CLICK
  overlay.addEventListener('click', function () {
    mobileMenu.classList.remove('active');
    overlay.classList.remove('active');
  });

});
</script>


<script>
document.addEventListener('DOMContentLoaded', function () {

  const cartBtn = document.querySelector('.js-cart-toggle');

  if (!cartBtn) return;

  cartBtn.addEventListener('click', function (e) {

    // 🚫 stop default + duplicate triggers
    e.preventDefault();
    e.stopImmediatePropagation();

    // ✅ prevent double click spam
    if (cartBtn.classList.contains('opening')) return;
    cartBtn.classList.add('opening');

    const drawer = document.querySelector('cart-drawer');

    if (drawer) {
      drawer.open(); // Dawn method
    } else {
      console.warn('Cart drawer not found');
    }

    // remove lock after animation
    setTimeout(() => {
      cartBtn.classList.remove('opening');
    }, 500);

  }, true); // 🔥 capture phase (important)

});
</script>